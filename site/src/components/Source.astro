---
// The public citation stays readable while the linked registry retains the
// exact file/section and epistemic label for technical review.
import { claims, type ClaimId } from "../data/claims";
import { repoDoc } from "../config";

interface Props {
  id: ClaimId;
  /** Extra ids whose sources merge into one line. */
  also?: ClaimId[];
}
const { id, also = [] } = Astro.props;
const entries = [id, ...also].map((cid) => claims[cid]);
const labelNames = {
  VF: "Verified evidence",
  EI: "Evidence-backed analysis",
  TH: "Testable hypothesis",
  DD: "Design specification",
  OQ: "Open question",
} as const;
const labels = [...new Set(entries.map((entry) => labelNames[entry.label]))];
const registryUrl = `${repoDoc("site/CLAIMS.md")}#claim-${id}`;
---

<p class="claim-source">
  <span>Evidence: {labels.join(" · ")}</span>
  <span aria-hidden="true"> · </span>
  <a href={registryUrl}>Technical provenance</a>
</p>

<style>
  .claim-source {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    line-height: 1.5;
    letter-spacing: 0.02em;
    color: var(--ref-ink-3);
    margin: 0;
  }
</style>
