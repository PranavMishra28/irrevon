---
// The docs-section nav list. Rendered twice by DocsShell (a plain desktop
// sidebar and a mobile <details> disclosure) so no JS is needed for either;
// only one instance is displayed (the other is display:none, out of the
// accessibility tree).
import { getCollection } from "astro:content";
import manifest from "../../docs-manifest.json";
import { href } from "../lib/url";

const guides = (await getCollection("guides")).sort((a, b) => a.data.order - b.data.order);

const referenceSections = ["Design", "Benchmark", "Contracts", "Governance"] as const;
const referenceBySection = referenceSections.map((section) => ({
  section,
  entries: manifest.render.filter((e) => e.section === section),
}));

const current = Astro.url.pathname.replace(/\/$/, "");
const isCurrent = (path: string) => current === href(path).replace(/\/$/, "");

// Short sidebar labels; page titles come from the manifest.
const refTitle: Record<string, string> = {
  "rfc-001": "RFC-001 · first slice",
  "rfc-002": "RFC-002 · engine design",
  "benchmark-preregistration": "Benchmark preregistration",
  "execution-plan": "Execution plan",
  ci: "CI — how this repo builds",
  "security-policy": "Security policy",
  schemas: "Schemas — contract map",
  licensing: "Licensing status",
  decisions: "Decision records (ADRs)",
};
---

<nav aria-label="Docs section">
  <p class="docs-side-head"><a href={href("/docs/")}>Docs home</a></p>
  <p class="docs-side-head"><a href={href("/docs/search/")}>Search the docs</a></p>
  <h2 class="docs-side-group">Guides</h2>
  <ul>
    {
      guides.map((g) => (
        <li>
          <a href={href(`/docs/${g.id}/`)} aria-current={isCurrent(`/docs/${g.id}`) ? "page" : undefined}>
            {g.data.title}
          </a>
        </li>
      ))
    }
  </ul>
  {
    referenceBySection.map(({ section, entries }) => (
      <>
        <h2 class="docs-side-group">{section}</h2>
        <ul>
          {entries.map((e) => (
            <li>
              <a
                href={href(`/docs/reference/${e.slug}/`)}
                aria-current={isCurrent(`/docs/reference/${e.slug}`) ? "page" : undefined}
              >
                {refTitle[e.slug] ?? e.slug}
              </a>
            </li>
          ))}
        </ul>
      </>
    ))
  }
  <h2 class="docs-side-group">Decisions</h2>
  <ul>
    <li>
      <a
        href={href("/docs/reference/decisions/")}
        aria-current={isCurrent("/docs/reference/decisions") ? "page" : undefined}
      >
        ADR index (all records)
      </a>
    </li>
  </ul>
</nav>

<style is:global>
  .docs-side-head {
    margin: 0 0 10px;
    font-weight: 600;
  }
  .docs-side-head a {
    color: var(--ref-ink-1);
    text-decoration: none;
  }
  .docs-side-head a:hover {
    color: var(--ref-accent);
  }
  .docs-side-group {
    font-family: var(--font-mono);
    font-size: var(--site-text-2xs);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ref-ink-3);
    margin: 18px 0 8px;
  }
  .docs-side nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 2px;
  }
  .docs-side nav ul a {
    display: block;
    padding: 4px 8px;
    margin-left: -8px;
    border-radius: 2px;
    color: var(--ref-ink-2);
    text-decoration: none;
    line-height: 1.4;
  }
  .docs-side nav ul a:hover {
    color: var(--ref-ink-1);
    background: var(--ref-layer-panel);
  }
  .docs-side nav ul a[aria-current="page"] {
    color: var(--ref-ink-1);
    background: var(--ref-layer-panel);
    box-shadow: inset 2px 0 0 var(--ref-accent);
  }
</style>
