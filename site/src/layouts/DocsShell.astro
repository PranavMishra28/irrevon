---
// Shared shell for the docs section: persistent section nav (guides +
// rendered reference docs + search) beside the document. Under 900px the
// sidebar becomes a <details> disclosure — no JS involved; the nav is
// rendered twice (DocsNav) and only one instance is displayed.
import Base from "./Base.astro";
import DocsNav from "../components/DocsNav.astro";

interface Props {
  title: string;
  description: string;
  jsonLd?: Record<string, unknown>[];
}
const { title, description, jsonLd = [] } = Astro.props;
---

<Base title={title} description={description} ogImage="/og/og-docs.png" jsonLd={jsonLd}>
  <div class="container docs-grid">
    <aside class="docs-side">
      <div class="docs-side-desktop">
        <DocsNav />
      </div>
      <details class="docs-side-mobile">
        <summary>Docs navigation</summary>
        <DocsNav />
      </details>
    </aside>
    <div class="docs-main">
      <slot />
    </div>
  </div>
</Base>

<style>
  .docs-grid {
    display: grid;
    grid-template-columns: 232px minmax(0, 1fr);
    gap: clamp(28px, 4vw, 56px);
    padding-block: clamp(32px, 5vw, 56px);
    align-items: start;
  }
  .docs-side {
    position: sticky;
    top: 24px;
    max-height: calc(100vh - 48px);
    overflow-y: auto;
    font-size: var(--site-text-small);
    min-width: 0;
  }
  .docs-main {
    min-width: 0;
  }
  .docs-main :global(.doc-article) {
    grid-template-columns: minmax(0, 1fr);
    min-width: 0;
    width: 100%;
  }
  .docs-main :global(.doc-article > *) {
    max-width: 100%;
  }
  .docs-main :global(.doc-body) {
    justify-self: stretch;
    max-width: 100%;
    min-width: 0;
    overflow-wrap: anywhere;
    width: auto;
  }
  .docs-main :global(.mono-chip) {
    max-width: 100%;
    overflow-wrap: anywhere;
    white-space: normal;
  }
  .docs-main :global(h1),
  .docs-main :global(h2),
  .docs-main :global(h3),
  .docs-main :global(h4) {
    overflow-wrap: anywhere;
  }
  .docs-main :global(.doc-body ul),
  .docs-main :global(.doc-body ol),
  .docs-main :global(.doc-body li) {
    max-width: 100%;
    min-width: 0;
    overflow-wrap: anywhere;
  }
  .docs-side-mobile {
    display: none;
  }

  @media (max-width: 899px) {
    .docs-grid {
      grid-template-columns: minmax(0, 1fr);
      gap: 20px;
    }
    .docs-side {
      position: static;
      max-height: none;
      overflow: visible;
    }
    .docs-side-desktop {
      display: none;
    }
    .docs-side-mobile {
      display: block;
      border: 1px solid var(--ref-border);
      border-radius: 2px;
      background: var(--ref-layer-panel);
    }
    .docs-side-mobile > summary {
      cursor: pointer;
      padding: 12px 14px;
      font-weight: 500;
    }
    .docs-side-mobile[open] > summary {
      border-bottom: 1px solid var(--ref-border-subtle);
    }
    .docs-side-mobile :global(nav) {
      padding: 12px 16px 16px;
    }
  }
</style>
