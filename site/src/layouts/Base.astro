---
import "../styles/site.css";
import Mark from "../components/Mark.astro";
import { SITE_NAME, REPO_URL, repoDoc } from "../config";
import { serializeJsonLd } from "../lib/jsonld-serialization";
import { BUILD_COMMIT, BUILD_COMMIT_SHORT, BUILT_AT } from "../lib/provenance";
import { href } from "../lib/url";
import { normalizePathname, robotsDirective } from "../../search-policy.mjs";

interface Props {
  title: string;
  description: string;
  /** OpenGraph type; research posts pass "article". */
  ogType?: "website" | "article";
  /** Path (under the site base) to this page's OG card; defaults to the site card. */
  ogImage?: string;
  /** ISO date for article:published_time (research posts). */
  publishedTime?: string;
  /** Adds <link rel="alternate"> to the research RSS feed. */
  rssAlternate?: boolean;
  /** JSON-LD structured-data objects (rendered as data blocks; never offers/ratings). */
  jsonLd?: Record<string, unknown>[];
  /** Accessible description of the social card. */
  ogImageAlt?: string;
}
const {
  title,
  description,
  ogType = "website",
  ogImage = "/og/og-default.png",
  publishedTime,
  rssAlternate = false,
  jsonLd = [],
  ogImageAlt = "Irrevon — evidence-first reconciliation for irreversible AI-agent actions",
} = Astro.props;
const ogImageAbs = new URL(href(ogImage), Astro.site);

const nav = [
  { label: "Product", path: "/platform/" },
  { label: "How it works", path: "/how-it-works/" },
  { label: "Demo", path: "/demo/" },
  { label: "Benchmark", path: "/benchmark/" },
  { label: "Docs", path: "/docs/" },
  { label: "Install", path: "/install/" },
  { label: "Contribute", path: "/contributing/" },
];
const footerPages = [
  { label: "Status", path: "/status/" },
  { label: "Security", path: "/security/" },
  { label: "Privacy", path: "/privacy/" },
  { label: "Contributing", path: "/contributing/" },
  { label: "License", path: "/licensing/" },
  { label: "Changelog", path: "/changelog/" },
  { label: "Roadmap", path: "/roadmap/" },
];

const canonicalPath = normalizePathname(Astro.url.pathname);
if (!canonicalPath) throw new Error("irrevon-site: generated page has a noncanonical pathname");
const canonical = new URL(canonicalPath, Astro.site);
canonical.search = "";
canonical.hash = "";
const isVercelPreview = Boolean(process.env.VERCEL_ENV && process.env.VERCEL_ENV !== "production");
const robots = isVercelPreview ? "noindex,nofollow" : robotsDirective(Astro.url.pathname);
const isHome = Astro.url.pathname === "/";
const verificationToken = (name: string): string | undefined => {
  const value = process.env[name]?.trim();
  if (!value) return undefined;
  if (!/^[A-Za-z0-9._~+/-]{8,256}$/.test(value)) {
    throw new Error(`irrevon-site: ${name} contains unsupported characters`);
  }
  return value;
};
const googleVerification = isHome ? verificationToken("GOOGLE_SITE_VERIFICATION") : undefined;
const bingVerification = isHome ? verificationToken("BING_SITE_VERIFICATION") : undefined;
const enableCustomEvents = process.env.SITE_ENABLE_CUSTOM_EVENTS === "1";
const retainCampaignParameters = process.env.SITE_ENABLE_UTM_ANALYTICS === "1";
const current = Astro.url.pathname.replace(/index\.html$/, "");
const isCurrent = (path: string) => {
  const target = href(path).replace(/\/$/, "");
  const normalized = current.replace(/\/$/, "");
  return normalized === target || (target !== "" && normalized.startsWith(`${target}/`));
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    {googleVerification && <meta name="google-site-verification" content={googleVerification} />}
    {bingVerification && <meta name="msvalidate.01" content={bingVerification} />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={href("/favicon.svg")} type="image/svg+xml" />
    <meta name="color-scheme" content="light dark" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <!-- Open Graph / Twitter. Image URLs are absolute from the deploy-provided
         site origin; the committed cards are drift-gated (scripts/build-og.mjs). -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {
      rssAlternate && (
        <link
          rel="alternate"
          type="application/rss+xml"
          title={`${SITE_NAME} — Research`}
          href={href("/research/rss.xml")}
        />
      )
    }
    {jsonLd.map((obj) => <script type="application/ld+json" set:html={serializeJsonLd(obj)} />)}
    <!-- Theme boot: honors a stored explicit choice before first paint.
         Without JS, tokens.css's generated prefers-color-scheme block applies. -->
    <script is:inline>
      (() => {
        try {
          const t = localStorage.getItem("theme");
          if (t === "light" || t === "dark") document.documentElement.dataset.theme = t;
        } catch {
          /* storage unavailable: system preference applies */
        }
      })();
    </script>
    <!-- Vercel Web Analytics + Speed Insights (owner directive, ADR-0029): the
         static-HTML snippets. Cookieless, first-party — both loaders and their
         beacon endpoints live on this origin (/_vercel/...); off-Vercel (local
         dev, CI preview) the loaders 404 harmlessly and nothing beacons. The
         bootstrap below is hashed into the per-page CSP like every inline script. -->
    <script is:inline define:vars={{ retainCampaignParameters }}>
      window.va =
        window.va ||
        function () {
          (window.vaq = window.vaq || []).push(arguments);
        };
      window.si =
        window.si ||
        function () {
          (window.siq = window.siq || []).push(arguments);
        };
      const irrevonTelemetryBeforeSend = (event) => {
        try {
          if (localStorage.getItem("irrevon-analytics-opt-out") === "1") return null;
          const url = new URL(event.url);
          const allowed = new Set(["utm_source", "utm_medium", "utm_campaign", "utm_content", "utm_term"]);
          for (const key of [...url.searchParams.keys()]) {
            const value = url.searchParams.get(key) || "";
            if (
              !retainCampaignParameters ||
              !allowed.has(key) ||
              !/^[a-z0-9][a-z0-9.-]{0,63}$/.test(value)
            ) {
              url.searchParams.delete(key);
            }
          }
          return { ...event, url: url.toString() };
        } catch {
          return null;
        }
      };
      window.va("beforeSend", irrevonTelemetryBeforeSend);
      window.si("beforeSend", irrevonTelemetryBeforeSend);
    </script>
    <script is:inline defer src="/_vercel/insights/script.js"></script>
    <script is:inline defer src="/_vercel/speed-insights/script.js"></script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="site-header">
      <div class="container header-inner">
        <a class="wordmark" href={href("/")} aria-label={`${SITE_NAME} — home`}>
          <Mark size={22} />
          <span class="wordmark-text">{SITE_NAME.toLowerCase()}</span>
        </a>
        <div class="primary-menu">
          <button
            id="menu-toggle"
            type="button"
            aria-expanded="false"
            aria-controls="primary-navigation"
            hidden
          >
            <span>Menu</span>
            <svg
              class="menu-chevron"
              viewBox="0 0 16 16"
              width="16"
              height="16"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              aria-hidden="true"
            >
              <path d="m4 6 4 4 4-4"></path>
            </svg>
          </button>
          <nav id="primary-navigation" aria-label="Primary">
            <ul class="nav-list">
              {
                nav.map((item) => (
                  <li>
                    <a href={href(item.path)} aria-current={isCurrent(item.path) ? "page" : undefined}>
                      {item.label}
                    </a>
                  </li>
                ))
              }
              <li>
                <a
                  href={REPO_URL}
                  data-analytics-event="repository_click"
                  data-analytics-placement="header">GitHub</a
                >
              </li>
            </ul>
          </nav>
        </div>
        <button id="theme-toggle" type="button" aria-label="Toggle color theme" hidden>
          <svg
            class="icon-sun"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            width="16"
            height="16"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="4"></circle>
            <path
              d="M12 2v3M12 19v3M2 12h3M19 12h3M4.9 4.9l2.1 2.1M17 17l2.1 2.1M19.1 4.9L17 7M7 17l-2.1 2.1"
            ></path>
          </svg>
          <svg
            class="icon-moon"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            width="16"
            height="16"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"></path>
          </svg>
        </button>
        <!-- Small framework-free behavior: the theme toggle and the
             privacy-bounded measurement hooks share the global inline budget. -->
        <script is:inline>
          (() => {
            const btn = document.getElementById("theme-toggle");
            if (!btn) return;
            btn.hidden = false;
            const systemDark = matchMedia("(prefers-color-scheme: dark)");
            const effective = () => document.documentElement.dataset.theme ?? (systemDark.matches ? "dark" : "light");
            const updateLabel = () => {
              const target = effective() === "dark" ? "light" : "dark";
              btn.setAttribute("aria-label", `Switch to ${target} theme`);
            };
            updateLabel();
            btn.addEventListener("click", () => {
              const next = effective() === "dark" ? "light" : "dark";
              document.documentElement.dataset.theme = next;
              try {
                localStorage.setItem("theme", next);
              } catch {
                /* persistence unavailable; the in-page toggle still applies */
              }
              updateLabel();
            });
            systemDark.addEventListener("change", updateLabel);
          })();
        </script>
        <script is:inline>
          (() => {
            const button = document.getElementById("menu-toggle");
            const navigation = document.getElementById("primary-navigation");
            if (!button || !navigation) return;
            const narrow = matchMedia("(max-width: 640px)");
            const applyMode = () => {
              if (narrow.matches) {
                button.hidden = false;
                navigation.hidden = button.getAttribute("aria-expanded") !== "true";
              } else {
                button.hidden = true;
                button.setAttribute("aria-expanded", "false");
                navigation.hidden = false;
              }
            };
            button.addEventListener("click", () => {
              const expanded = button.getAttribute("aria-expanded") === "true";
              button.setAttribute("aria-expanded", String(!expanded));
              navigation.hidden = expanded;
            });
            narrow.addEventListener("change", applyMode);
            applyMode();
          })();
        </script>
      </div>
    </header>

    <main id="main" tabindex="-1">
      <slot />
    </main>

    <!-- Optional Pro/Enterprise conversion events. The allowlist and fixed
         placement values prevent arbitrary or high-cardinality data. Hobby
         plans simply retain ordinary page analytics; navigation still works. -->
    <script is:inline define:vars={{ enableCustomEvents }}>
      (() => {
        if (!enableCustomEvents) return;
        const events = new Set([
          "repository_click",
          "clone_command_copy",
          "install_command_copy",
          "demo_start",
          "demo_complete",
          "video_start",
          "video_complete",
          "workbench_exploration",
          "documentation_entry",
          "benchmark_methodology_visit",
          "adapter_guide_visit",
          "contribution_click",
          "security_report_click",
          "launch_cta",
        ]);
        const placements = new Set([
          "header",
          "hero",
          "proof",
          "body",
          "footer",
          "install",
          "docs",
          "benchmark",
          "demo",
        ]);
        const measure = (name, placement) => {
          if (!events.has(name) || !placements.has(placement)) return;
          window.va?.("event", { name, data: { placement } });
        };
        window.irrevonMeasure = measure;
        addEventListener("click", (click) => {
          const target = click.target instanceof Element ? click.target.closest("[data-analytics-event]") : null;
          if (!target) return;
          const name = target.getAttribute("data-analytics-event");
          const placement = target.getAttribute("data-analytics-placement") || "body";
          measure(name, placement);
        });
        addEventListener("copy", () => {
          const selection = getSelection();
          const node = selection?.anchorNode;
          const element = node instanceof Element ? node : node?.parentElement;
          const target = element?.closest("[data-analytics-copy-event]");
          if (!target) return;
          measure(
            target.getAttribute("data-analytics-copy-event"),
            target.getAttribute("data-analytics-placement") || "body",
          );
        });
      })();
    </script>

    <footer class="site-footer">
      <div class="container">
        <div class="footer-grid">
          <div class="footer-brand">
            <span class="footer-lockup"><Mark size={18} /><span>{SITE_NAME.toLowerCase()}</span></span>
            <p class="footer-tag">
              Evidence-first reconciliation for irreversible AI-agent actions.
              Open source. Local-first. Scientific results are not claimed.
            </p>
          </div>
          <nav aria-label="Project links">
            <h2 class="footer-head">Explore</h2>
            <ul>
              <li>
                <a
                  href={REPO_URL}
                  data-analytics-event="repository_click"
                  data-analytics-placement="footer">GitHub</a
                >
              </li>
              <li>
                <a
                  href={href("/docs/")}
                  data-analytics-event="documentation_entry"
                  data-analytics-placement="footer">Documentation</a
                >
              </li>
              <li>
                <a
                  href={href("/demo/")}
                  data-analytics-event="demo_start"
                  data-analytics-placement="footer">Recorded demo</a
                >
              </li>
              <li><a href={repoDoc("LICENSE")}>Apache-2.0 source</a></li>
            </ul>
          </nav>
          <nav aria-label="Project policies">
            <h2 class="footer-head">Project</h2>
            <ul>
              {
                footerPages.map((item) => (
                  <li>
                    <a href={href(item.path)}>{item.label}</a>
                  </li>
                ))
              }
            </ul>
          </nav>
        </div>
        <div class="footer-status">
          <p>
            © 2026 Irrevon contributors · Apache-2.0 ·
            <a
              href={href("/security/")}
              data-analytics-event="security_report_click"
              data-analytics-placement="footer">Security</a
            > ·
            <a href={href("/status/")}>Research-preview status</a>
          </p>
          <p class="footer-provenance" data-provenance>
            Build {
              BUILD_COMMIT_SHORT ? (
                <>
                  commit <a href={`${REPO_URL}/commit/${BUILD_COMMIT}`}><code>{BUILD_COMMIT_SHORT}</code></a>
                </>
              ) : (
                <>commit unknown (built outside git)</>
              )
            } · {BUILT_AT}
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-header {
    background: var(--ref-layer-panel);
    border-bottom: 1px solid var(--ref-border);
  }
  .header-inner {
    display: flex;
    align-items: center;
    gap: clamp(14px, 3vw, 32px);
    min-height: 56px;
    flex-wrap: wrap;
    padding-block: 8px;
  }
  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    color: var(--ref-ink-1);
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: -0.01em;
  }
  .wordmark:hover {
    color: var(--ref-ink-1);
  }
  .primary-menu {
    flex: 1;
    min-width: 0;
  }
  #menu-toggle {
    display: none;
  }
  .primary-menu > nav {
    display: block;
  }
  .nav-list {
    display: flex;
    flex-wrap: wrap;
    gap: 2px 18px;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav-list a {
    display: inline-flex;
    align-items: center;
    min-height: 40px;
    font-size: var(--site-text-small);
    font-weight: 500;
    color: var(--ref-ink-2);
    text-decoration: none;
    border-bottom: 2px solid transparent;
  }
  .nav-list a:hover {
    color: var(--ref-ink-1);
  }
  .nav-list a[aria-current="page"] {
    color: var(--ref-ink-1);
    border-bottom-color: var(--ref-accent);
  }
  #theme-toggle {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--ref-border);
    border-radius: 4px;
    background: var(--ref-layer-panel);
    color: var(--ref-ink-2);
    cursor: pointer;
  }
  #theme-toggle:hover {
    color: var(--ref-ink-1);
    border-color: var(--ref-border-strong);
  }
  @media (max-width: 640px) {
    .header-inner {
      gap: 8px 14px;
    }
    .primary-menu {
      order: 3;
      flex-basis: 100%;
    }
    #menu-toggle {
      display: flex;
      align-items: center;
      justify-content: space-between;
      min-height: 40px;
      padding: 0 12px;
      border: 1px solid var(--ref-border);
      border-radius: 4px;
      color: var(--ref-ink-2);
      background: var(--ref-layer-panel);
      font-size: var(--site-text-small);
      font-weight: 600;
      cursor: pointer;
    }
    #menu-toggle:hover {
      color: var(--ref-ink-1);
      border-color: var(--ref-border-strong);
    }
    .primary-menu > nav:not([hidden]) {
      padding-top: 8px;
    }
    #menu-toggle[aria-expanded="true"] .menu-chevron {
      transform: rotate(180deg);
    }
    .nav-list {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 2px 10px;
    }
    .nav-list a {
      width: 100%;
    }
  }
  /* The display rule above must not defeat the no-JS hidden attribute. */
  #theme-toggle[hidden],
  #menu-toggle[hidden],
  #primary-navigation[hidden] {
    display: none;
  }
  /* Show the icon for the theme you would switch TO. */
  .icon-sun {
    display: none;
  }
  :global([data-theme="dark"]) .icon-sun {
    display: block;
  }
  :global([data-theme="dark"]) .icon-moon {
    display: none;
  }
  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme])) .icon-sun {
      display: block;
    }
    :global(:root:not([data-theme])) .icon-moon {
      display: none;
    }
  }

  .site-footer {
    border-top: 1px solid var(--ref-border);
    background: var(--ref-layer-panel);
    padding-block: 36px 24px;
    margin-top: var(--site-section-gap);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: minmax(240px, 2fr) repeat(2, minmax(120px, 1fr));
    gap: 32px;
  }
  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 560px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
  .footer-lockup {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    color: var(--ref-ink-1);
  }
  .footer-tag {
    margin-top: 12px;
    font-size: var(--site-text-small);
    color: var(--ref-ink-2);
    max-width: 34ch;
  }
  .footer-head {
    font-family: var(--font-mono);
    font-size: var(--site-text-2xs);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ref-ink-3);
    margin-bottom: 12px;
  }
  .site-footer ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 8px;
  }
  .site-footer ul a {
    font-size: var(--site-text-small);
    color: var(--ref-ink-2);
    text-decoration: none;
  }
  .site-footer ul a:hover {
    color: var(--ref-accent);
    text-decoration: underline;
  }
  .footer-status {
    border-top: 1px solid var(--ref-border-subtle);
    margin-top: 32px;
    padding-top: 20px;
    display: grid;
    gap: 6px;
  }
  .footer-status p {
    font-size: var(--site-text-2xs);
    font-family: var(--font-mono);
    line-height: 1.6;
    color: var(--ref-ink-3);
    max-width: 90ch;
  }
</style>
