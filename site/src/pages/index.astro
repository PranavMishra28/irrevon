---
import Base from "../layouts/Base.astro";
import Badge from "../components/Badge.astro";
import Source from "../components/Source.astro";
import DemoTranscript from "../components/DemoTranscript.astro";
import OneWayStage from "../components/OneWayStage.astro";
import Icon from "../components/Icon.astro";
import { SITE_NAME, BENCH_NAME, REPO_URL, repoDoc } from "../config";
import { href, asset } from "../lib/url";
import { softwareSourceCode, webSite } from "../lib/jsonld";

const siteUrl = new URL(href("/"), Astro.site);
const searchUrl = new URL(href("/docs/search/"), Astro.site);
---

<Base
  title={`${SITE_NAME} — honest handling of irreversible AI-agent actions`}
  description="A preregistered benchmark and reference reconciliation engine for irreversible AI-agent actions. Identity from stable business identifiers, persist-before-dispatch, reconcile-by-query. Pre-release, open research."
  jsonLd={[softwareSourceCode(siteUrl), webSite(siteUrl, searchUrl)]}
>
  <!-- ── Hero ─────────────────────────────────────────────────────────── -->
  <section class="section hero">
    <div class="container hero-grid">
      <div>
        <span class="kicker">Reconciliation for irreversible agent effects</span>
        <h1 class="hero-title">Agents retry.<br />Destinations don’t forgive.</h1>
        <p class="lead hero-lead">
          An agent that crashes mid-call, retries a timeout, or re-synthesizes its arguments can charge a card
          twice, book the wrong slot, or leave an orphaned order no process reconciles. {SITE_NAME} is an
          open-source reference engine — and a preregistered benchmark — for exactly that failure.
        </p>
        <Source id="problem-ambiguous-outcome" also={["resynthesis-defeats-keys"]} />
        <div class="hero-ctas">
          <a class="btn btn-primary" href={REPO_URL}>View the source</a>
          <a class="btn btn-secondary" href={href("/how-it-works/")}>How it works</a>
        </div>
        <p class="hero-note">
          Pre-release · not on any package index · benchmark preregistration is a draft, no runs yet
        </p>
      </div>
      <aside class="hero-proof" aria-label="Recorded demo outcome">
        <div class="badge-row">
          <Badge kind="recorded" />
        </div>
        <!-- Beat-10 poster crop (0 JS): evidence returns through the boundary
             port; the seated effect never moves — the thesis in one still. -->
        <figure class="hero-poster">
          <OneWayStage mode="poster" />
          <figcaption class="hero-proof-note">
            Beat 10 of the recorded sequence: evidence returns; the effect does not.
          </figcaption>
        </figure>
        <a class="btn btn-secondary hero-poster-cta" href={href("/demo/") + "#beat-01"}>
          <svg viewBox="0 0 12 12" width="10" height="10" aria-hidden="true" fill="currentColor">
            <path d="M2 1 L11 6 L2 11 Z"></path>
          </svg>
          Step through the recorded sequence
        </a>
        <p class="hero-proof-line">
          Same fault schedule — a lost response, a SIGKILL, a re-synthesized retry — recorded twice:
        </p>
        <dl class="hero-proof-stats">
          <div>
            <dt>{SITE_NAME} leg</dt>
            <dd><strong>1</strong> destination effect</dd>
            <dd class="hero-proof-note">duplicate rejected, with evidence</dd>
          </div>
          <div>
            <dt>B5 baseline leg</dt>
            <dd><strong>2</strong> destination effects</dd>
            <dd class="hero-proof-note">idempotency key sent — and ignored</dd>
          </div>
        </dl>
        <p class="hero-proof-src"><Source id="demo-contrast" /></p>
        <a class="hero-proof-link" href="#recorded">See the full transcript ↓</a>
      </aside>
    </div>
  </section>

  <!-- ── Recorded artifact ────────────────────────────────────────────── -->
  <section class="section" id="recorded">
    <div class="container">
      <div class="section-head">
        <span class="kicker">Evidence, not a promise</span>
        <h2>One crash, one lost response, one re-synthesized retry. Two very different endings.</h2>
        <p class="lead">
          The flagship demo persists an intent, loses the dispatch response on cue, is really SIGKILLed, and
          recovers by asking the destination — then rejects the agent’s re-worded retry as a duplicate of the
          same stable identity. The strongest conventional baseline, under the identical fault schedule,
          creates the duplicate.
        </p>
      </div>
      <DemoTranscript />
    </div>
  </section>

  <!-- ── Three mechanisms ─────────────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="kicker">The mechanism</span>
        <h2>Three deterministic moves</h2>
      </div>
      <div class="grid-3">
        <article class="panel-subtle pillar">
          <span class="pillar-index"><Icon name="stable-id" size={20} /> 01</span>
          <h3>Identity from business facts, never model output</h3>
          <p>
            Effect identity is a hash of stable upstream identifiers — order IDs, invoice IDs, authorization
            IDs — plus effect type and scope. A re-synthesized retry with different wording collapses to the
            same identity. No key-derivation path reads model output; that is conformance-tested.
          </p>
          <Source id="identity-stable-ids" />
        </article>
        <article class="panel-subtle pillar">
          <span class="pillar-index"><Icon name="persist" size={20} /> 02</span>
          <h3>Persist before dispatch</h3>
          <p>
            Nothing is sent without a durable record carrying the operation identity and idempotency evidence.
            A crash before persistence is therefore provably effect-free — and a crash after it leaves a record
            that recovery must adjudicate.
          </p>
          <Source id="persist-before-dispatch" />
        </article>
        <article class="panel-subtle pillar">
          <span class="pillar-index"><Icon name="probe" size={20} /> 03</span>
          <h3>Reconcile by asking the destination</h3>
          <p>
            Ambiguous outcomes are resolved by querying the destination’s authoritative status — never by
            believing the caller. Anything unrecognized stays AMBIGUOUS, never silently FAILED, so evidence is
            never discarded.
          </p>
          <Source id="reconcile-by-query" />
        </article>
      </div>
    </div>
  </section>

  <!-- ── The honesty block ────────────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="kicker">Stated up front, not in a footnote</span>
        <h2>What {SITE_NAME} cannot do</h2>
        <p class="lead">
          The non-guarantees carry the same weight as the guarantees. That is the point of the project.
        </p>
      </div>
      <div class="grid-2">
        <article class="panel cannot">
          <h3>No universal exactly-once</h3>
          <p>
            Impossible per Two Generals / FLP. The achievable target is at-least-once delivery plus idempotent
            or reconciled processing — and the guarantee depends on what the destination exposes.
          </p>
          <Source id="no-exactly-once" />
        </article>
        <article class="panel cannot">
          <h3>Compensation is not rollback</h3>
          <p>
            A committed irreversible effect cannot be un-committed. Compensation is a new effect with its own
            failure modes — measured, never assumed.
          </p>
          <Source id="compensation-not-rollback" />
        </article>
        <article class="panel cannot">
          <h3>No advantage on C1 — expected, and pre-committed</h3>
          <p>
            Destinations with dependable native idempotency already prevent duplicates. {SITE_NAME} expects to
            add nothing there, and the benchmark pre-commits to reporting that null as prominently as any win.
          </p>
          <Source id="c1-null-precommit" />
        </article>
        <article class="panel cannot">
          <h3>C3 is an impossibility boundary</h3>
          <p>
            Opaque destinations — no key, no query, no stable ID — make lost and orphaned effects undetectable
            for every method. The benchmark demonstrates that boundary instead of hiding it.
          </p>
          <Source id="tiers-table" />
        </article>
      </div>
    </div>
  </section>

  <!-- ── Workbench imagery ────────────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="kicker">The product surface</span>
        <h2>Every claim ends in an inspectable record</h2>
        <p class="lead">
          The workbench is a local, read-only viewer over the ledger: lifecycle, classification, and resolution
          as three separate dimensions, per-effect causal evidence, and findings with their evidence digests.
        </p>
      </div>
      <figure class="screenshot themed-shot">
        <img
          class="shot-light"
          src={asset("/images/workbench-effects-light.png")}
          alt="Irrevon workbench Effects table listing recorded effects with separate lifecycle, classification, and resolution columns; a synthetic-fixture banner is visible at the top."
          width="1440"
          height="900"
          loading="lazy"
        />
        <img
          class="shot-dark"
          src={asset("/images/workbench-effects-dark.png")}
          alt="Irrevon workbench Effects table in dark theme, listing recorded effects with separate lifecycle, classification, and resolution columns; a synthetic-fixture banner is visible at the top."
          width="1440"
          height="900"
          loading="lazy"
        />
        <figcaption>
          The workbench pictured is running against schema-validated fixtures captured from a real engine run
          (seed 777) — the SYNTHETIC FIXTURE banner is part of the product, not an accident of the screenshot.
        </figcaption>
      </figure>
      <div class="badge-row" style="margin-top: 12px;">
        <Badge kind="recorded" />
      </div>
      <Source id="workbench-fixture-screens" />
    </div>
  </section>

  <!-- ── Benchmark teaser ─────────────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="kicker">{BENCH_NAME}</span>
        <h2>The benchmark is preregistered before a single run — including the result that would kill the project</h2>
      </div>
      <div class="status-banner" role="note">
        <span class="status-title">Preregistered methodology — no results yet</span>
        <p>
          The preregistration is a <strong>draft</strong>; nothing is frozen and no benchmark run has occurred.
          If the strongest conventional baseline matches {SITE_NAME} on C2 destinations, the pre-committed
          falsification criterion fires: {SITE_NAME} is unnecessary, and the project says so.
        </p>
        <Source id="prereg-draft-status" also={["kill-criterion"]} />
      </div>
      <p style="margin-top: 20px;">
        <a href={href("/benchmark/")}>Read the benchmark design and the kill criterion →</a>
      </p>
    </div>
  </section>

  <!-- ── Get started ──────────────────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="kicker">Get started</span>
        <h2>Clone it and run the flagship demo</h2>
        <p class="lead">
          Pre-release: nothing is on a package index, and the repository carries no license yet. The demo runs
          locally against a deterministic reference destination — about five minutes with uv and Docker.
        </p>
      </div>
      <pre><code>git clone {REPO_URL}.git && cd irrevon
uv sync --locked        # toolchain + deps, pinned by uv.lock
uv run irrevon init      # config, compose file, then migrations
docker compose up -d --wait
uv run irrevon doctor    # read-only checks incl. the identity self-test
uv run irrevon demo      # the two-leg flagship story</code></pre>
      <div style="margin-top: 14px;">
        <Source id="quickstart-real" also={["not-published", "license-pending"]} />
      </div>
      <div class="hero-ctas" style="margin-top: 24px;">
        <a class="btn btn-primary" href={REPO_URL}>Open the repository</a>
        <a class="btn btn-secondary" href={repoDoc("docs/master-doc.md")}>Read the master document</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero {
    padding-top: clamp(64px, 10vw, 112px);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(0, 1fr);
    gap: clamp(32px, 5vw, 72px);
    align-items: center;
  }
  @media (max-width: 1023px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
  }
  .hero-title {
    font-size: var(--site-text-display);
    line-height: 1.08;
    letter-spacing: -0.02em;
    max-width: 18ch;
    margin-top: 4px;
  }
  .hero-proof {
    border: 1px solid var(--ref-border);
    border-radius: 2px;
    background: var(--ref-layer-panel);
    padding: clamp(20px, 2.5vw, 28px);
    display: grid;
    gap: 16px;
    align-content: start;
  }
  .hero-proof-line {
    font-size: var(--site-text-small);
    color: var(--ref-ink-2);
  }
  .hero-proof-stats {
    display: grid;
    gap: 0;
    border: 1px solid var(--ref-border-subtle);
    border-radius: 2px;
  }
  .hero-proof-stats > div {
    padding: 14px 16px;
    display: grid;
    gap: 2px;
  }
  .hero-proof-stats > div + div {
    border-top: 1px solid var(--ref-border-subtle);
  }
  .hero-proof-stats dt {
    font-family: var(--font-mono);
    font-size: var(--site-text-2xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ref-ink-3);
  }
  .hero-proof-stats dd {
    margin: 0;
    color: var(--ref-ink-1);
  }
  .hero-proof-stats dd strong {
    font-size: 1.375rem;
    font-variant-numeric: tabular-nums;
  }
  .hero-proof-note {
    font-family: var(--font-mono);
    font-size: var(--site-text-2xs);
    color: var(--ref-ink-2);
  }
  .hero-proof-src {
    margin: 0;
  }
  .hero-proof-link {
    font-size: var(--site-text-small);
    font-weight: 500;
  }
  .hero-lead {
    margin-top: 22px;
    margin-bottom: 14px;
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }
  .hero-note {
    margin-top: 18px;
    font-family: var(--font-mono);
    font-size: var(--site-text-2xs);
    letter-spacing: 0.04em;
    color: var(--ref-ink-3);
  }
  .pillar {
    display: grid;
    gap: 12px;
    align-content: start;
  }
  .pillar-index {
    font-family: var(--font-mono);
    font-size: var(--site-text-2xs);
    color: var(--ref-ink-3);
    letter-spacing: 0.1em;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .hero-poster {
    display: grid;
    gap: 8px;
    border: 1px solid var(--ref-border-subtle);
    border-radius: 2px;
    background: var(--ref-layer-sunken);
    padding: 12px 14px 10px;
  }
  .hero-poster-cta {
    justify-self: start;
  }
  .hero-poster-cta svg {
    flex: none;
  }
  .pillar p {
    color: var(--ref-ink-2);
  }
  .cannot {
    display: grid;
    gap: 10px;
    align-content: start;
  }
  .cannot p {
    color: var(--ref-ink-2);
  }
</style>
