---
import Base from "../layouts/Base.astro";
import Source from "../components/Source.astro";
import { SITE_NAME, REPO_URL, repoDoc } from "../config";

const docLinks = [
  {
    name: "Master document",
    path: "docs/master-doc.md",
    desc: "The single authoritative document: thesis, evidence, architecture, state model, benchmark design, decisions, operations. Hash-pinned; amended only by human ratification.",
  },
  {
    name: "RFC-002 — engine design",
    path: "docs/rfc-002-engine-design.md",
    desc: "Implementation-ready mechanics: canonical state tables, ledger and locked transitions, claim protocol, gate, recovery, sweep, and the M3 test plan.",
  },
  {
    name: "Benchmark preregistration (DRAFT)",
    path: "docs/benchmark-preregistration.md",
    desc: "Hypotheses, matrix, metrics, analysis plan, invalid-run rules, sealed-holdout protocol, and the falsification criterion. Nothing frozen; no runs.",
  },
  {
    name: "Schemas + examples",
    path: "schemas/README.md",
    desc: "Machine-readable contracts: intent contract, effect record, dispatch receipt, reconciliation finding, capability declaration — each with valid and invalid example suites enforced in CI.",
  },
  {
    name: "Security policy",
    path: "docs/security-policy.md",
    desc: "The development threat model and agent execution policy: what agents may do, what is human-only, and the enforcement layers.",
  },
  {
    name: "Execution plan",
    path: "docs/execution-plan.md",
    desc: "Roadmap, phases, and gates — including the public-release gate that everything publishable waits behind.",
  },
  {
    name: "Decision records",
    path: "docs/decisions/README.md",
    desc: "Append-only ADR index (0000–0023): every settled decision with its rejected alternatives and reopen trigger. If a decision is not in the index, it has not been made.",
  },
  {
    name: "Licensing status",
    path: "LICENSING.md",
    desc: "Why the repository currently carries no license and accepts no contributions, and what closes that decision.",
  },
  {
    name: "Workbench (frontend) README",
    path: "web/README.md",
    desc: "The read-only evidence workbench: budgets, fixture provenance, zero-external-request guarantees, and how to run it locally.",
  },
];
---

<Base
  title={`Docs — ${SITE_NAME}`}
  description="Run the flagship demo from a clone in about five minutes, and read the canonical repository documents: master document, RFC-002, benchmark preregistration, schemas, security policy."
>
  <section class="section">
    <div class="container">
      <span class="kicker">Docs</span>
      <h1>Everything canonical lives in the repository</h1>
      <p class="lead" style="margin-top: 18px;">
        This site introduces the project; it does not duplicate its documentation. The documents below are the
        source of truth — versioned, linked, and reviewable where they live.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="kicker">Quickstart</span>
        <h2>Clone, and run the flagship demo</h2>
        <p class="lead">
          Honest prerequisites: <a href="https://docs.astral.sh/uv/">uv</a>, Docker (for a local, pinned
          Postgres 17), and about five minutes. There is no package-index install yet — once publication
          clearances close, it will be <code>uv tool install irrevon</code>; until then, clone.
        </p>
      </div>
      <pre><code># pre-release: clone only — no package-index install exists
git clone {REPO_URL}.git && cd irrevon

uv sync --locked                # toolchain + deps, pinned by uv.lock
uv run irrevon init              # writes irrevon.toml, compose.yaml, .env.example
cp .env.example .env            # local placeholder password (never committed)
docker compose up -d --wait     # digest-pinned Postgres 17, loopback only
uv run irrevon init              # now applies the plain-SQL migrations
uv run irrevon doctor            # read-only checks incl. the identity self-test
uv run irrevon demo              # the two-leg flagship story</code></pre>
      <div style="margin-top: 14px;">
        <Source id="quickstart-real" also={["not-published"]} />
      </div>
      <div class="panel-subtle" style="margin-top: 24px; max-width: 80ch;">
        <h3>The 30-minute integration target</h3>
        <p class="muted" style="margin-top: 8px;">
          The integration surface is a thin wrapper at the tool-call boundary: the agent
          calls <code>registerIntent</code> then <code>dispatch</code>; reconcile, sweep, and resolve are
          library-driven. The stated target — a stranger integrates against one sandbox in under 30 minutes —
          is a target with a test (the stranger test), not an achievement. It will be measured, not asserted.
        </p>
        <div style="margin-top: 10px;"><Source id="thirty-min-target" /></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="kicker">Canonical documents</span>
        <h2>Read the originals</h2>
      </div>
      <ul class="doc-list">
        {
          docLinks.map((d) => (
            <li>
              <a href={repoDoc(d.path)}>{d.name}</a>
              <p>{d.desc}</p>
              <span class="mono-chip">{d.path}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="kicker">Status, plainly</span>
        <h2>Pre-release, unlicensed, no contributions yet</h2>
      </div>
      <div class="grid-3">
        <article class="panel-subtle status-card">
          <h3>Not published</h3>
          <p>
            No package index carries this project. The name is decided — Irrevon (ADR-0023); PyPI registration
            of “irrevon” is unblocked pending external clearances and the counsel trademark screen. Publication
            remains a human act at the release gate.
          </p>
          <Source id="not-published" />
        </article>
        <article class="panel-subtle status-card">
          <h3>License pending decision record</h3>
          <p>
            The repository is publicly readable but carries no license: the decision between an
            engine-AGPL-3.0 / harness-Apache-2.0 hybrid and all-Apache-2.0 is an open decision record
            (ADR-0014) that closes at the public-release gate. Until then, no contributions are accepted.
          </p>
          <Source id="license-pending" />
        </article>
        <article class="panel-subtle status-card">
          <h3>Governed in writing</h3>
          <p>
            Solo-maintained, built with AI coding agents under a documented execution policy. The master
            document is hash-pinned, decision records are append-only, and open questions live in a
            human-resolved review queue.
          </p>
          <Source id="solo-governed" />
        </article>
      </div>
    </div>
  </section>
</Base>

<style>
  .doc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
  }
  @media (max-width: 800px) {
    .doc-list {
      grid-template-columns: 1fr;
    }
  }
  .doc-list li {
    border: 1px solid var(--ref-border-subtle);
    border-radius: 2px;
    background: var(--ref-layer-panel);
    padding: 20px 22px;
    display: grid;
    gap: 10px;
    align-content: start;
    justify-items: start;
  }
  .doc-list a {
    font-weight: 600;
    font-size: 1rem;
  }
  .doc-list p {
    color: var(--ref-ink-2);
    font-size: var(--site-text-small);
  }
  .status-card {
    display: grid;
    gap: 10px;
    align-content: start;
  }
  .status-card p {
    color: var(--ref-ink-2);
  }
</style>
