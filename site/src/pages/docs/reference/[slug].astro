---
// Rendered repository documents (repo-docs collection, generated by
// scripts/sync-docs.mjs). Every page carries a provenance banner; bodies are
// the repository markdown, mechanically transformed only.
import { getCollection, render } from "astro:content";
import DocsShell from "../../../layouts/DocsShell.astro";
import RenderedFrom from "../../../components/RenderedFrom.astro";
import Badge from "../../../components/Badge.astro";
import { techArticle, breadcrumbs } from "../../../lib/jsonld";
import { href } from "../../../lib/url";

export async function getStaticPaths() {
  const docs = await getCollection("repo-docs");
  return docs.map((doc) => ({ params: { slug: doc.id }, props: { doc } }));
}

const { doc } = Astro.props;
const { Content, headings } = await render(doc);
const toc = headings.filter((h) => h.depth === 2);
const description =
  doc.data.description ??
  `Rendered copy of ${doc.data.sourcePath} — the repository copy is canonical; this rendering is drift-gated.`;
const pageUrl = new URL(href(`/docs/reference/${doc.id}/`), Astro.site);
const visibleHeading = doc.data.renderTitle
  ? doc.data.title
  : headings.find((heading) => heading.depth === 1)?.text ?? doc.data.title;
const jsonLd = [
  techArticle({ title: visibleHeading, description, url: pageUrl }),
  breadcrumbs([
    { name: "Docs", url: new URL(href("/docs/"), Astro.site) },
    { name: visibleHeading, url: pageUrl },
  ]),
];
---

<DocsShell title={`${doc.data.title} — Irrevon docs`} description={description} jsonLd={jsonLd}>
  <article class="doc-article" data-pagefind-body>
    <RenderedFrom
      sourcePath={doc.data.sourcePath}
      sourceSha256={doc.data.sourceSha256}
      syncedAt={doc.data.syncedAt}
    />
    {
      doc.data.badge && (
        <div class="badge-row doc-badges">
          <Badge kind={doc.data.badge} />
        </div>
      )
    }
    {
      doc.data.adr && (
        <dl class="adr-meta">
          <div>
            <dt>Record</dt>
            <dd>{doc.data.adr.id}</dd>
          </div>
          {doc.data.adr.status && (
            <div>
              <dt>Status</dt>
              <dd>{doc.data.adr.status}</dd>
            </div>
          )}
          {doc.data.adr.date && (
            <div>
              <dt>Date</dt>
              <dd>{doc.data.adr.date}</dd>
            </div>
          )}
          {doc.data.adr.supersedes && (
            <div>
              <dt>Supersedes</dt>
              <dd>{doc.data.adr.supersedes}</dd>
            </div>
          )}
        </dl>
      )
    }
    {doc.data.renderTitle && <h1>{doc.data.title}</h1>}
    {
      toc.length > 2 && (
        <nav class="doc-toc" aria-label="On this page">
          <h2>On this page</h2>
          <ul>
            {toc.map((h) => (
              <li>
                <a href={`#${h.slug}`}>{h.text}</a>
              </li>
            ))}
          </ul>
        </nav>
      )
    }
    <div class="doc-body">
      <Content />
    </div>
  </article>
</DocsShell>

<style is:global>
  .doc-article {
    display: grid;
    gap: 18px;
    justify-items: start;
  }
  .doc-badges {
    margin: 0;
  }
  .adr-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 28px;
    margin: 0;
    border: 1px solid var(--ref-border-subtle);
    border-radius: 2px;
    background: var(--ref-layer-panel);
    padding: 12px 16px;
    font-size: var(--site-text-small);
  }
  .adr-meta div {
    display: grid;
    gap: 2px;
  }
  .adr-meta dt {
    font-family: var(--font-mono);
    font-size: var(--site-text-2xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ref-ink-3);
  }
  .adr-meta dd {
    margin: 0;
    color: var(--ref-ink-1);
  }
  .doc-toc {
    border: 1px solid var(--ref-border-subtle);
    border-radius: 2px;
    background: var(--ref-layer-panel);
    padding: 14px 18px;
    font-size: var(--site-text-small);
    max-width: 100%;
  }
  .doc-toc h2 {
    font-family: var(--font-mono);
    font-size: var(--site-text-2xs);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ref-ink-3);
    margin-bottom: 8px;
  }
  .doc-toc ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 4px;
  }

  /* Markdown body typography (.doc-body) lives in site.css — shared with
     guides and research posts. */
</style>
