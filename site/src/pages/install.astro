---
// /install — source and release installation with one provenance boundary.
// Package-index commands are conditional on the Status page reporting the
// exact release; the install e2e also ensures that the old squatted name never
// appears in an install command.
import Base from "../layouts/Base.astro";
import Source from "../components/Source.astro";
import { SITE_NAME, REPO_URL } from "../config";
import { href } from "../lib/url";

const packageName = SITE_NAME.toLowerCase();
const releaseInstalls = [
  { cmd: `uvx ${packageName}`, note: "run without installing" },
  { cmd: `uv tool install ${packageName}`, note: "recommended isolated CLI install" },
  { cmd: `pipx install ${packageName}`, note: "isolated CLI install" },
  { cmd: `pip install ${packageName}`, note: "install into the active Python environment" },
];
---

<Base
  title={`Install — ${SITE_NAME}`}
  description="Install Irrevon from a verified release or from source, then run the deterministic local demo with uv and Docker."
  ogImage="/og/og-install.png"
>
  <section class="section">
    <div class="container">
      <span class="kicker">Install</span>
      <h1>Install the Alpha. Verify what you run.</h1>
      <p class="lead" style="margin-top: 18px; max-width: 64ch;">
        Release availability and build identity live on the <a href={href("/status/")}>Status page</a> and in{" "}
        <a href={href("/version.json")}><code>/version.json</code></a>. Use a package command only when that
        status identifies the exact version you intend to install. The Apache-2.0 source path remains available.
      </p>
    </div>
  </section>

  <section class="section" id="from-source">
    <div class="container">
      <div class="section-head">
        <span class="kicker">Source checkout</span>
        <h2>Build and run locally</h2>
        <p class="lead">
          Prerequisites, honestly: <a href="https://docs.astral.sh/uv/">uv</a>, Docker (for a local,
          digest-pinned Postgres 17 on loopback), and Git.
        </p>
      </div>
      <pre data-analytics-copy-event="install_command_copy" data-analytics-placement="install"><code>git clone {REPO_URL}.git && cd {packageName}

uv sync --locked                # toolchain + deps, pinned by uv.lock
uv run irrevon init             # writes irrevon.toml, compose.yaml, .env.example
cp .env.example .env            # local migration bootstrap; no credential
set -a && . ./.env && set +a    # export the generated migration DSN
docker compose up -d --wait     # digest-pinned Postgres 17, loopback only
uv run irrevon init             # now applies the plain-SQL migrations
uv run irrevon doctor           # non-destructive checks; includes a rolled-back write probe
uv run irrevon demo             # the two-leg flagship story</code></pre>
      <div style="margin-top: 14px;">
        <Source id="quickstart-real" />
      </div>
      <p style="margin-top: 18px;">
        Then step through what the demo recorded: <a href={href("/demo/")}>the One-Way Seat</a>, or follow the{" "}
        <a href={href("/docs/getting-started/")}>getting-started guide</a>.
      </p>
    </div>
  </section>

  <section class="section" id="release-install">
    <div class="container">
      <div class="section-head">
        <span class="kicker">Versioned release</span>
        <h2>Use the package registry only after verification</h2>
        <p class="lead">
          Irrevon distributes as one package with the Workbench embedded. The Status page links the canonical
          package and GitHub release records and identifies the release commit.
        </p>
      </div>
      <div class="release-block" data-release-install>
        <div class="release-head">
          <span class="release-chip">VERIFY RELEASE STATUS</span>
          <span class="mono-chip">v0.1.0 Alpha</span>
        </div>
        <ul class="release-list">
          {
            releaseInstalls.map((releaseInstall) => (
              <li>
                <code>{releaseInstall.cmd}</code>
                <span>{releaseInstall.note}</span>
              </li>
            ))
          }
        </ul>
        <p class="release-note">
          Before installation, confirm the exact version on <a href={href("/status/")}>Status</a>. Published
          artifacts are built by the protected release workflow with checksums, an SBOM, and attestations;
          PyPI publication uses OIDC Trusted Publishing rather than a repository token.
        </p>
        <Source id="install-gated" also={["license-apache2"]} />
      </div>
    </div>
  </section>

  <section class="section" id="uninstall">
    <div class="container">
      <div class="section-head">
        <span class="kicker">Leaving</span>
        <h2>Uninstall</h2>
        <p class="lead">Remove the package or source checkout, then remove local demo state if you created it.</p>
      </div>
      <pre><code>uv tool uninstall {packageName} # when installed with uv tool
docker compose down -v          # drop the disposable local demo database volume
cd .. && rm -rf {packageName}   # remove a source checkout and its project-local files</code></pre>
      <p class="muted" style="margin-top: 14px; font-size: var(--site-text-small);">
        The volume command is destructive. Do not run it against data you need to retain.
      </p>
    </div>
  </section>
</Base>

<style>
  .release-block {
    border: 1px dashed var(--ref-border-strong);
    border-radius: 2px;
    background: var(--ref-layer-panel);
    padding: clamp(20px, 3vw, 32px);
    display: grid;
    gap: 16px;
    max-width: 76ch;
  }
  .release-head {
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
  }
  .release-chip {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: 1px dashed var(--ref-border-strong);
    border-radius: 2px;
    padding: 5px 8px;
    color: var(--ref-ink-2);
  }
  .release-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 10px;
  }
  .release-list li {
    display: flex;
    gap: 16px;
    align-items: baseline;
    flex-wrap: wrap;
  }
  .release-list code {
    min-width: 26ch;
  }
  .release-list span {
    color: var(--ref-ink-3);
    font-size: var(--site-text-small);
  }
  .release-note {
    color: var(--ref-ink-2);
    font-size: var(--site-text-small);
    max-width: 64ch;
  }
</style>
