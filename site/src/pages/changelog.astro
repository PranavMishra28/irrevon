---
// Publication truth comes from docs/project-status.json. Phase A commits a
// candidate; Phase B changes that one record only after PyPI, the GitHub
// Release, and the release commit have been independently verified. This does
// not depend on Vercel's checkout containing Git tags.
import Base from "../layouts/Base.astro";
import { SITE_NAME } from "../config";
import {
  GITHUB_RELEASE_URL,
  PYPI_PROJECT_URL,
  RELEASE_COMMIT,
  RELEASE_STATE,
  RELEASE_TAG,
  RELEASE_VERSION,
  RELEASED_AT,
} from "../lib/release-provenance";
import { href } from "../lib/url";

const published = RELEASE_STATE === "published";
const releaseDate = RELEASED_AT?.slice(0, 10);
---

<Base
  title={`Changelog — ${SITE_NAME}`}
  description={
    published
      ? `${SITE_NAME} ${RELEASE_VERSION} Alpha release history, linked to its verified package and GitHub Release.`
      : `${SITE_NAME} ${RELEASE_VERSION} Alpha candidate status. Package publication is in progress.`
  }
>
  <section class="section">
    <div class="container">
      <span class="kicker">Changelog</span>
      <h1>{published ? "Released software" : "Alpha release candidate"}</h1>
      <p class="lead" style="margin-top: 18px; max-width: 64ch;">
        {
          published
            ? "This entry is rendered from the repository’s machine-readable release record, updated only after the package, release, and source commit are verified."
            : "Irrevon 0.1.0 Alpha is prepared and under final release validation. Source installation remains available while package publication completes."
        }
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {
        published ? (
          <ol class="tag-list">
            <li>
              <span class="mono-chip">{RELEASE_TAG}</span>
              {releaseDate && <time datetime={releaseDate}>{releaseDate}</time>}
              <h2>Irrevon {RELEASE_VERSION} Alpha</h2>
              <p>
                The reconciliation engine, continuous single-writer worker, local read-only
                Workbench, deterministic synthetic demonstration, and benchmark development
                harness are available as the first public software release.
              </p>
              <p>
                <a href={PYPI_PROJECT_URL}>PyPI package</a> ·{" "}
                <a href={GITHUB_RELEASE_URL}>GitHub Release and artifacts</a>
              </p>
              {RELEASE_COMMIT && (
                <p class="empty-derived mono-chip">release commit {RELEASE_COMMIT}</p>
              )}
            </li>
          </ol>
        ) : (
          <div class="empty-state">
            <span class="mono-chip">{RELEASE_TAG} candidate</span>
            <h2>Package release in progress</h2>
            <p class="empty-body">
              The reviewed Alpha candidate is not represented as published until independent
              checks confirm both PyPI and the corresponding GitHub Release.
            </p>
            <div class="empty-links">
              <a href={href("/install/")}>Install from source</a>
              <a href={href("/status/")}>Current project status</a>
            </div>
          </div>
        )
      }
    </div>
  </section>
</Base>

<style>
  .empty-state {
    border: 1px dashed var(--ref-border-strong);
    border-radius: 2px;
    background: var(--ref-layer-panel);
    padding: clamp(28px, 5vw, 56px);
    display: grid;
    gap: 14px;
    max-width: 72ch;
    justify-items: start;
  }
  .empty-body {
    color: var(--ref-ink-2);
    max-width: 58ch;
  }
  .empty-derived {
    margin-top: 4px;
    white-space: normal;
    overflow-wrap: anywhere;
  }
  .empty-links {
    display: grid;
    gap: 8px;
    font-size: var(--site-text-small);
    margin-top: 6px;
  }
  .tag-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 14px;
    max-width: 72ch;
  }
  .tag-list li {
    border: 1px solid var(--ref-border-subtle);
    border-radius: 2px;
    background: var(--ref-layer-panel);
    padding: 16px 20px;
    display: grid;
    gap: 6px;
    justify-items: start;
  }
  .tag-list time {
    font-family: var(--font-mono);
    font-size: var(--site-text-2xs);
    color: var(--ref-ink-3);
  }
</style>
