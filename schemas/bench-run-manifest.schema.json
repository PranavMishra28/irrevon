{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://irrevon.dev/schemas/bench-run-manifest.schema.json",
  "$comment": "irrevonbench/run-manifest/v1 (preregistration §8) — proposed by ADR-0030. Written FIRST (write-ahead registration): a run that dies pre-evidence still exists. Immutable once written; the result document references it by digest. Records the exact system under test (arm version, configuration, retry behavior, model/scaffold where relevant, known deviations) so every comparison is auditable. $id host is a placeholder (ADR-0023). Shape changes require an ADR.",
  "title": "IrrevonBench run manifest (write-ahead)",
  "type": "object",
  "properties": {
    "format": { "const": "irrevonbench/run-manifest/v1" },
    "run_id": { "type": "string", "pattern": "^run_[0-9a-z_.-]{4,80}$" },
    "created_at": { "type": "string", "format": "date-time" },
    "harness_version": { "type": "string", "minLength": 1 },
    "confirmatory": {
      "description": "TRUE only for Stage-B-governed confirmatory runs. The harness refuses to set this before the preregistration freeze record exists (integrity refusal, exit 4).",
      "type": "boolean"
    },
    "plan": {
      "type": "object",
      "properties": {
        "manifest_root_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "workload_id": { "type": "string", "pattern": "^wl_[0-9a-z_.-]{4,80}$" },
        "schedule_id": { "type": "string", "pattern": "^fs_[0-9a-z_.-]{4,80}$" },
        "variant_set_id": { "type": ["string", "null"], "pattern": "^vs_[0-9a-z_.-]{4,80}$" },
        "cell_id": { "type": "string", "minLength": 1 },
        "replicate_index": { "type": "integer", "minimum": 0 },
        "seed": {
          "description": "Decimal string: 64-bit seeds exceed the JCS safe-integer domain.",
          "type": "string",
          "pattern": "^(0|[1-9][0-9]{0,19})$"
        },
        "trial_count": { "type": "integer", "minimum": 1 }
      },
      "required": [
        "manifest_root_hash",
        "workload_id",
        "schedule_id",
        "variant_set_id",
        "cell_id",
        "replicate_index",
        "seed",
        "trial_count"
      ],
      "additionalProperties": false
    },
    "arm": {
      "description": "The system under test, pinned exactly (preregistration §8; MLPerf-style system description).",
      "type": "object",
      "properties": {
        "arm_id": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "config_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "retry_behavior": { "type": "string", "minLength": 1 },
        "model": { "type": ["string", "null"] },
        "prompt_scaffold_digest": { "type": ["string", "null"], "pattern": "^sha256:[0-9a-f]{64}$" },
        "capability_declaration_digest": { "type": ["string", "null"], "pattern": "^sha256:[0-9a-f]{64}$" },
        "known_deviations": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "required": [
        "arm_id",
        "description",
        "version",
        "config_digest",
        "retry_behavior",
        "model",
        "prompt_scaffold_digest",
        "capability_declaration_digest",
        "known_deviations"
      ],
      "additionalProperties": false
    },
    "environment_digest": {
      "description": "sha256 over the canonical bytes of the run's irrevonbench/environment/v1 document.",
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "reset_verification": {
      "description": "Pre-run fixture-reset proof (preregistration §6/§8): destination state verified empty/known before the run. Failure ⇒ harness-INVALID.",
      "type": "object",
      "properties": {
        "verified": { "type": "boolean" },
        "readback_digest": { "type": ["string", "null"], "pattern": "^sha256:[0-9a-f]{64}$" }
      },
      "required": ["verified", "readback_digest"],
      "additionalProperties": false
    },
    "replaces_run_id": {
      "description": "Set when this run replaces a harness-INVALID replicate slot (same seed, at most twice per slot, §6). Null otherwise.",
      "type": ["string", "null"],
      "pattern": "^run_[0-9a-z_.-]{4,80}$"
    }
  },
  "required": [
    "format",
    "run_id",
    "created_at",
    "harness_version",
    "confirmatory",
    "plan",
    "arm",
    "environment_digest",
    "reset_verification",
    "replaces_run_id"
  ],
  "additionalProperties": false
}
