{
  "name": "detent-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0 <25",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.15.1",
  "scripts": {
    "dev": "vite --mode development",
    "build": "vite build",
    "build:review": "vite build --mode review",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:styles": "stylelint \"src/**/*.css\"",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run --project unit",
    "test:stories": "vitest run --project storybook",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "e2e": "playwright test --project e2e",
    "vrt": "playwright test --project vrt",
    "codegen": "node scripts/codegen.mjs",
    "codegen:check": "node scripts/codegen.mjs --check",
    "fonts:sync": "node scripts/sync-fonts.mjs",
    "size": "size-limit",
    "check": "pnpm typecheck && pnpm lint && pnpm lint:styles && pnpm format:check && pnpm codegen:check && pnpm fixtures:check && pnpm fonts:sync --check && pnpm test",
    "fixtures:check": "node scripts/verify-fixtures.mjs"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-router": "1.170.18",
    "@tanstack/react-table": "8.21.3",
    "lucide-react": "1.0.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@ibm/plex-mono": "2.5.0",
    "@ibm/plex-sans": "1.1.0",
    "@playwright/test": "1.61.1",
    "@size-limit/preset-app": "12.1.0",
    "@storybook/addon-a11y": "10.5.0",
    "@storybook/addon-vitest": "10.5.0",
    "@storybook/react-vite": "10.5.0",
    "@tailwindcss/vite": "4.3.2",
    "@tanstack/eslint-plugin-query": "5.101.2",
    "@tanstack/eslint-plugin-router": "1.162.0",
    "@tanstack/router-plugin": "1.168.20",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/browser-playwright": "4.1.10",
    "eslint": "10.7.0",
    "eslint-plugin-boundaries": "7.0.2",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "json-schema-to-typescript": "15.0.4",
    "msw": "2.15.0",
    "prettier": "3.9.5",
    "size-limit": "12.1.0",
    "storybook": "10.5.0",
    "stylelint": "16.26.1",
    "stylelint-declaration-strict-value": "1.11.1",
    "tailwindcss": "4.3.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "eslint-import-resolver-typescript": "4.4.5"
  }
}
